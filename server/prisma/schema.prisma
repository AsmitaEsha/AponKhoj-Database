generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  firstName             String
  lastName              String
  email                 String    @unique
  phone                 String    @unique
  location              String
  district              String?
  password              String
  role                  String    @default("user")
  avatarUrl             String?
  cloudinaryPublicId    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  posts                 Post[]
  missingPersonReports  MissingPersonReport[]
  foundPersonReports    FoundPersonReport[]
  adminActions          AdminAction[]
  reports               Report[]
  notifications         Notification[]

  @@map("User")
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String
  content   String?
  userId    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("Post")
}

model MissingPersonReport {
  id                    Int       @id @default(autoincrement())
  userId                Int
  name                  String
  age                   Int?
  gender                String?
  height                String?
  photoUrl              String?
  cloudinaryPublicId    String?
  lastSeenDate          DateTime?
  lastSeenTime          String?
  district              String
  address               String?
  clothingDescription   String?
  additionalInfo        String?
  contactPersonName     String
  contactPhone          String
  status                String    @default("pending")
  approved              Boolean   @default(false)
  rejectionReason       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([approved])
  @@index([createdAt(sort: Desc)])
  @@map("missing_person_reports")
}

model FoundPersonReport {
  id                    Int       @id @default(autoincrement())
  userId                Int
  name                  String
  age                   Int?
  gender                String?
  height                String?
  photoUrl              String?
  cloudinaryPublicId    String?
  foundDate             DateTime
  foundTime             String?
  district              String
  address               String?
  clothingDescription   String?
  additionalInfo        String?
  contactPersonName     String
  contactPhone          String
  status                String    @default("pending")
  approved              Boolean   @default(false)
  rejectionReason       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([approved])
  @@index([createdAt(sort: Desc)])
  @@map("found_person_reports")
}

model AdminAction {
  id                    Int       @id @default(autoincrement())
  adminId               Int
  reportType            String
  reportId              Int
  action                String
  reason                String?
  createdAt             DateTime  @default(now())

  admin                 User      @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt(sort: Desc)])
  @@index([reportType])
  @@map("admin_actions")
}

model Report {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  title       String
  description String
  location    String?
  imageUrl    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("reports")
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // 'report_approved' | 'report_rejected'
  title       String
  message     String
  reportType  String   // 'missing_person' | 'found_person'
  reportId    Int
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}