// Prisma schema for MS SQL Server with Windows Authentication
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// User model - Updated to match registration form
model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  name      String?
  password  String?
  phone     String?
  location  String?  // Division/District
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

// Post model
model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}