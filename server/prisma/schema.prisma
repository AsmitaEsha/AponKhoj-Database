generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  firstName             String
  lastName              String
  email                 String    @unique
  phone                 String    @unique
  location              String
  district              String?
  password              String
  role                  String    @default("user")
  avatarUrl             String?
  cloudinaryPublicId    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  posts                 Post[]
  missingPersonReports  MissingPersonReport[]
  foundPersonReports    FoundPersonReport[]
  adminActions          AdminAction[]
  reports               Report[]
  notifications         Notification[]
  alertNotifications    AlertNotification[]

  @@map("User")
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String
  content   String?
  userId    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("Post")
}

model MissingPersonReport {
  id                    Int       @id @default(autoincrement())
  userId                Int
  name                  String
  age                   Int?
  gender                String?
  height                String?
  photoUrl              String?
  cloudinaryPublicId    String?
  lastSeenDate          DateTime?
  lastSeenTime          String?
  district              String
  address               String?
  clothingDescription   String?
  additionalInfo        String?
  contactPersonName     String
  contactPhone          String
  status                String    @default("pending")
  approved              Boolean   @default(false)
  rejectionReason       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches               Match[]   @relation("MissingMatches")
  alertNotifications    AlertNotification[]

  @@index([userId])
  @@index([status])
  @@index([approved])
  @@index([createdAt(sort: Desc)])
  @@map("missing_person_reports")
}

model AlertNotification {
  id          Int      @id @default(autoincrement())
  userId      Int
  reportId    Int
  district    String
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  report      MissingPersonReport @relation(fields: [reportId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([reportId])
  @@index([district])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("alert_notifications")
}

model FoundPersonReport {
  id                    Int       @id @default(autoincrement())
  userId                Int
  name                  String
  age                   Int?
  gender                String?
  height                String?
  photoUrl              String?
  cloudinaryPublicId    String?
  foundDate             DateTime
  foundTime             String?
  district              String
  address               String?
  clothingDescription   String?
  additionalInfo        String?
  contactPersonName     String
  contactPhone          String
  status                String    @default("pending")
  approved              Boolean   @default(false)
  rejectionReason       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches               Match[]   @relation("FoundMatches")

  @@index([userId])
  @@index([status])
  @@index([approved])
  @@index([createdAt(sort: Desc)])
  @@map("found_person_reports")
}

model AdminAction {
  id                    Int       @id @default(autoincrement())
  adminId               Int
  reportType            String
  reportId              Int
  action                String
  reason                String?
  createdAt             DateTime  @default(now())

  admin                 User      @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt(sort: Desc)])
  @@index([reportType])
  @@map("admin_actions")
}

model Report {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  title       String
  description String
  location    String?
  imageUrl    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("reports")
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // 'report_approved' | 'report_rejected'
  title       String
  message     String
  reportType  String   // 'missing_person' | 'found_person'
  reportId    Int
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model Match {
  id                    Int       @id @default(autoincrement())
  foundReportId         Int
  missingReportId       Int
  matchType             String    // 'ai_match' | 'admin_verified' | 'user_reported'
  similarityScore       Decimal   @db.Decimal(5, 2) // 0-100
  matchStatus           String    @default("pending") // 'pending' | 'verified' | 'rejected' | 'reunited'
  notes                 String?
  matchedAt             DateTime  @default(now())
  reunitedat            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  foundReport           FoundPersonReport   @relation("FoundMatches", fields: [foundReportId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  missingReport         MissingPersonReport @relation("MissingMatches", fields: [missingReportId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([foundReportId, missingReportId])
  @@index([foundReportId])
  @@index([missingReportId])
  @@index([matchStatus])
  @@index([matchType])
  @@index([matchedAt(sort: Desc)])
  @@map("matches")
}